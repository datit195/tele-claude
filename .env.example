# Copy to .env in this repo root and fill in your credentials.
# The bot and hook dispatcher auto-load this file on startup; any var
# already set in the shell environment wins over the .env value.

# Required: Telegram bot token from @BotFather.
CLAUDE_TELEGRAM_BOT_TOKEN=your-bot-token

# Required: your Telegram chat ID (or comma-separated list for multi-user ACL).
CLAUDE_TELEGRAM_CHAT_ID=123456789

# Optional: override where inbound images are cached.
#TELE_CLAUDE_IMAGE_DIR=/custom/path

# Optional: override the state directory (default ~/.cache/tele-claude).
#TELE_CLAUDE_STATE_DIR=/custom/path

# Optional: minimum idle seconds before Claude Code's idle_prompt is forwarded.
#TELE_CLAUDE_IDLE_MIN_SECONDS=900
