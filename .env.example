# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
CLAUDE_TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram chat ID (numeric)
# Visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates to find it
CLAUDE_TELEGRAM_CHAT_ID=123456789

# OpenAI API Key (for output summarization)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
