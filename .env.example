# Copy to .env and fill in your values. The bot and hook dispatcher load
# this file automatically on startup (via Node's built-in --env-file logic).

# From @BotFather
CLAUDE_TELEGRAM_BOT_TOKEN=your-bot-token

# Comma-separated allowlist. Messages from any other chat are ignored.
CLAUDE_TELEGRAM_CHAT_ID=123456789

# Optional: override where state/cache files live (default ~/.cache/tele-claude)
# TELE_CLAUDE_STATE_DIR=/var/cache/tele-claude

# Optional: override where inbound images get saved (default ~/.cache/tele-claude/images)
# TELE_CLAUDE_IMAGE_DIR=/srv/tele-claude/images

# Optional: minimum quiet seconds before an idle_prompt notification fires
# (default 900 = 15 min). Claude Code's own idle timer is hardcoded at 60 s.
# TELE_CLAUDE_IDLE_MIN_SECONDS=900

# Optional: override where this repo lives so the hook wrappers + env loader
# find dist/ and .env. Defaults to the dirname of the running hooks.js file.
# TELE_CLAUDE_HOME=/opt/tele-claude
