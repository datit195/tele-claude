{
  "name": "tele-claude",
  "version": "0.1.0",
  "description": "Telegram bot for forwarding messages to Claude Code tmux panes",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "tele-claude": "dist/bot.js",
    "tele-claude-hooks": "dist/hooks.js",
    "tele-claude-format": "dist/format-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bot.ts",
    "start": "node dist/bot.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepare": "tsc"
  },
  "dependencies": {
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0"
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md"
  ]
}
