{
  "name": "tele-claude",
  "version": "0.1.0",
  "description": "Telegram bot for forwarding messages to Claude Code tmux panes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tele-claude": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "telegram",
    "bot",
    "claude",
    "tmux",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
